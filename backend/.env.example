# TG EAPCET College Predictor - Environment Variables Template
# ─────────────────────────────────────────────────────────────

# Neon PostgreSQL connection string
# Get this from: https://neon.tech -> Your Project -> Connection Details
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Server port (Render/Railway will auto-set this)
PORT=3001

# Environment
NODE_ENV=production

# Comma-separated list of allowed frontend origins for CORS
# Set this to your actual Vercel deployment URL
FRONTEND_URL="https://your-app.vercel.app"
